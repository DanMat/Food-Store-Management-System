# Copy to .env (gitignored). cloud-init writes DOMAIN on the VM automatically.

# Domain Caddy serves and provisions a TLS cert for. Use "localhost" locally.
DOMAIN=localhost

# Demo DB credentials. The DB ports are NOT published — they're only reachable
# inside the Docker network — so these are safe defaults for a demo. Override
# for anything real.
DB_ROOT_PASSWORD=rootpw
DB_APP_PASSWORD=foodmart
